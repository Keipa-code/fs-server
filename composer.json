{
    "autoload": {
        "psr-4": {
            "App\\Controller\\": "src/Controller",
            "App\\Entity\\": "src/Entity",
            "App\\Command\\" : "src/Command",
            "App\\Middleware\\" : "src/Middleware",
            "App\\Renderer\\" : "src/Renderer"
        }
    },
    "require": {
        "twbs/bootstrap": "4.5.3",
        "monolog/monolog": "^2.2",
        "slim/slim": "4.*",
        "slim/psr7": "^1.3",
        "php-di/php-di": "^6.3",
        "slim/twig-view": "^3.2",
        "roave/psr-container-doctrine": "^2.2",
        "semhoun/proxy-detection-middleware": "^0.5.0",
        "slim/flash": "^0.4.0",
        "symfony/console": "^4.2"
    },
    "config": {

        "platform-check": false
    }
}
